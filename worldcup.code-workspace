{
  "folders": [
    {
      "name": "workspace-root",
      "path": "."
    }
  ],
  "settings": {
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "files.exclude": {
      "**/__pycache__": true
    },
    "peacock.color": "#0891b2",
    "workbench.colorCustomizations": {
      "activityBar.background": "#0891b2",
      "titleBar.activeBackground": "#0891b2",
      "statusBar.background": "#0891b2"
    }
  }
}
